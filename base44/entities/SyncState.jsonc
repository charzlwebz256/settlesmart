{
  "name": "SyncState",
  "type": "object",
  "properties": {
    "sync_token": {
      "type": "string",
      "description": "Google Calendar sync token for incremental updates"
    },
    "last_sync": {
      "type": "string",
      "format": "date-time",
      "description": "Last successful sync timestamp"
    },
    "description": {
      "type": "string",
      "maxLength": 1000,
      "description": "Optional description or notes about this sync state"
    }
  },
  "required": []
}