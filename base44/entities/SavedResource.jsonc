{
  "name": "SavedResource",
  "type": "object",
  "properties": {
    "service_id": {
      "type": "string",
      "description": "ID of the saved service"
    },
    "notes": {
      "type": "string",
      "description": "User's personal notes"
    },
    "status": {
      "type": "string",
      "enum": [
        "saved",
        "contacted",
        "in_progress",
        "completed"
      ],
      "default": "saved"
    }
  },
  "required": [
    "service_id"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "created_by": "{{user.email}}"
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}